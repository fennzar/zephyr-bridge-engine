{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": false,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": false,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "node"
    ],
    "baseUrl": "./src",
    "paths": {
      "@shared/*": [
        "shared/*"
      ],
      "@domain/*": [
        "domain/*"
      ],
      "@infra/*": [
        "infra/*"
      ],
      "@services/*": [
        "services/*"
      ],
      "@shared": [
        "shared/index.ts"
      ],
      "@domain": [
        "domain/index.ts"
      ],
      "@infra": [
        "infra/index.ts"
      ],
      "@services": [
        "services/index.ts"
      ]
    }
  },
  "exclude": [
    "node_modules",
    ".next"
  ]
}