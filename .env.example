# === Chain selection ===
NODE_ENV=development
ZEPHYR_ENV=local                    # local | sepolia | mainnet

# === Database (required) ===
DATABASE_URL=postgresql://zephyr_bridge_arb:zephyr_bridge_arb@localhost:5432/zephyr_bridge_arb

# === EVM RPC URLs ===
RPC_URL_LOCAL_HTTP=http://127.0.0.1:8545
RPC_URL_LOCAL_WS=ws://127.0.0.1:8545
RPC_URL_SEPOLIA_HTTP=
RPC_URL_SEPOLIA_WS=
RPC_URL_MAINNET_HTTP=
RPC_URL_MAINNET_WS=

# === Zephyr Daemon ===
ZEPHYR_D_RPC_URL=http://remote-node.zephyrprotocol.com:17767
ZEPHYR_WALLET_RPC_URL=              # e.g. http://127.0.0.1:48771/json_rpc
ZEPHYR_WALLET_PASSWORD=

# === EVM Wallet ===
EVM_PRIVATE_KEY=                    # 0x-prefixed hex (DO NOT COMMIT REAL KEYS)
EVM_WALLET_ADDRESS=                 # 0x-prefixed address

# === MEXC (optional — leave blank for paper-only) ===
MEXC_API_KEY=
MEXC_API_SECRET=
MEXC_PAPER=true                     # true: simulate orders using paper ledger

# === Paper / Simulation ===
ZEPHYR_PAPER=true                   # true: simulate native Zephyr operations

# === CEX Wallets (real wallets for simulated exchange) ===
CEX_WALLET_RPC_URL=http://127.0.0.1:48772/json_rpc
CEX_ADDRESS=
CEX_PK=
# FAKE_ORDERBOOK_ENABLED=true       # typically set via Procfile, not .env
# FAKE_ORDERBOOK_PORT=5556          # typically set via Procfile, not .env

# === App / Dashboard ===
NEXT_PUBLIC_APP_NAME=Zephyr Bridge Engine
NEXT_PUBLIC_BASE_URL=http://localhost:7000

# === Watchers ===
EVM_WATCHER_PORT=7010
MEXC_WATCHER_PORT=7020
